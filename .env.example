# Primary connection — used by Prisma Client at runtime.
# When using Supabase: use the connection pooler URL (port 6543).
DATABASE_URL="postgresql://user:password@localhost:5432/lodestar_dev"

# Direct connection — used by Prisma Migrate (bypasses the pooler).
# When using Supabase: use the direct connection URL (port 5432).
DIRECT_URL="postgresql://user:password@localhost:5432/lodestar_dev"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Anthropic
ANTHROPIC_API_KEY=""
